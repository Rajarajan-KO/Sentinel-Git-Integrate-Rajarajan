	measure 'Last 24 month' =
			
			var CurrentDate = TODAY()
			var Date24MonthsAgo = EDATE(CurrentDate, -25)
			
			// Current Month YYYYMM integer
			var a = VALUE(FORMAT(CurrentDate, "YYYYMM"))
			
			// Month 24 months ago YYYYMM integer
			var b = VALUE(FORMAT(Date24MonthsAgo, "YYYYMM"))
			
			RETURN
			IF(
			    MIN(Trend_chart_30_09[period_id]) >= b && MAX(Trend_chart_30_09[period_id]) <= a,
			    1,
			    0
			)
