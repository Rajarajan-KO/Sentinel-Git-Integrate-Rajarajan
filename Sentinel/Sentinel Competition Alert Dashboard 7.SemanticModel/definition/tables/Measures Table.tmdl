	measure 'Avg_price_Trend filter' =
			
			var tcc_=CALCULATE(DISTINCTCOUNT(brand_level_data[BRAND_OWNER]),USERELATIONSHIP('BRAND TABLE'[Key for brand table],brand_level_data[KEY FOR BRAND TABLE]),ALL(brand_level_data))
			var old=CALCULATE(MAX(Trend_chart_30_09[AVG_PRICE])
			,USERELATIONSHIP('BRAND TABLE'[Key for brand table],brand_level_data[KEY FOR BRAND TABLE]),TREATAS(VALUES(brand_level_data[BRAND]),Trend_chart_30_09[BRAND]),Trend_chart_30_09[CATEGORY]=SELECTEDVALUE('BRAND TABLE'[CATEGORY]))
			var new=CALCULATE(MAX(Trend_chart_30_09[AVG_PRICE]),USERELATIONSHIP('BRAND TABLE'[Key for brand table 2],brand_level_data[KEY FOR BRAND TABLE 2]),TREATAS(VALUES(brand_level_data[BRAND]),Trend_chart_30_09[BRAND]),Trend_chart_30_09[CATEGORY]=SELECTEDVALUE('BRAND TABLE'[CATEGORY]))
			var c=
			IF(tcc_=2,old,new)
			var final=
			IF(SELECTEDVALUE(Unit[Unit])="Price$/UC",DIVIDE(c,5.678,0),c)
			RETURN
			IF(ISFILTERED('BRAND TABLE'[ALERT_ID_2])||ISFILTERED('BRAND TABLE'[ALERT_ID]),final,BLANK())
		lineageTag: a1870221-3cd3-4df1-a205-6ef79d7afb07

