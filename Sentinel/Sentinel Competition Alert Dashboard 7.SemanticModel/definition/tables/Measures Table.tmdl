	measure 'Measure for Price_Change' =
			
			IF(ISFILTERED('BRAND TABLE'[ALERT_ID]),
			IF(SELECTEDVALUE('BRAND TABLE'[Price_Metric_2])="Previous 3MMT Price",
			            IF(ISBLANK(MAX('DASHBOARD DATA'[Current_Month_3MMT_Price])) || ISBLANK(MAX('DASHBOARD DATA'[Previous_3MMT_Price])),BLANK(),
			IF(MAX('DASHBOARD DATA'[Current_Month_3MMT_Price])=0 || MAX('DASHBOARD DATA'[Previous_3MMT_Price])=0,0,
			            DIVIDE(max('DASHBOARD DATA'[Current_Month_3MMT_Price]) , max('DASHBOARD DATA'[Previous_3MMT_Price]))-1)),
			IF(SELECTEDVALUE('BRAND TABLE'[Price_Metric_2])="YTD Price",
			            IF(ISBLANK(MAX('DASHBOARD DATA'[Current_Month_3MMT_Price])) || ISBLANK(MAX('DASHBOARD DATA'[YTD_Price])),BLANK(),
			IF(MAX('DASHBOARD DATA'[Current_Month_3MMT_Price])=0 || MAX('DASHBOARD DATA'[YTD_Price])=0,0,
			            DIVIDE(max('DASHBOARD DATA'[Current_Month_3MMT_Price]), max('DASHBOARD DATA'[YTD_Price]))-1)),BLANK())))
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 21af0a35-ca4c-45c1-bc7b-a1d0abc8bf27

