	measure 'MS Current Month' =
			
			IF(ISFILTERED('BRAND TABLE'[ALERT_ID]),
			SWITCH(SELECTEDVALUE(Unit[Unit]),
			"Value Share(USD)",IF(max('DASHBOARD DATA'[Current_Month_Market_Value_Share])=0,BLANK(),max('DASHBOARD DATA'[Current_Month_Market_Value_Share])/100),
			"Volume Share(UC)",IF(MAX('DASHBOARD DATA'[Current_Month_Market_Volume_Share])=0,BLANK(),MAX('DASHBOARD DATA'[Current_Month_Market_Volume_Share])/100)),BLANK())
